{
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/insights",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/score-risco",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/isho",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/esg-social",
      "schedule": "0 9 * * 2"
    },
    {
      "path": "/api/cron/eco-briefing",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/eco-radar",
      "schedule": "0 7 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/alana",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/alana-landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
